# Keep build context minimal — only what `pnpm build` actually needs.

# Node + package manager
node_modules
.pnpm-store
.pnp
.pnp.*
.yarn

# Next.js build outputs (rebuilt inside the image)
.next
out
build

# Local env files — never bake secrets into the image
.env
.env.*
!.env.example

# Git + editor
.git
.gitignore
.gitattributes
.vscode
.idea
.cursor

# CI / docs / misc
.github
*.md
!README.md
DEPLOY.md
LICENSE

# OS junk
.DS_Store
Thumbs.db

# Logs + caches
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.tsbuildinfo
next-env.d.ts

# Tests + coverage
coverage
.nyc_output

# Docker artifacts themselves (avoid recursion / wasted bytes)
docker
docker-compose*.yml
Dockerfile*
Caddyfile
deploy.sh
