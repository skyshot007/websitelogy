# Copy to `.env` on your Hostinger VPS (never commit `.env`).
# cp .env.example .env && nano .env

# --- Required for Docker + Caddy (HTTPS) ------------------------------------
DOMAIN=astroaniljoshi.tech
ACME_EMAIL=hello@astroaniljoshi.tech

# --- Site identity (baked into the Next.js build) ---------------------------
# Use https:// — Caddy redirects www → apex automatically.
NEXT_PUBLIC_SITE_URL=https://astroaniljoshi.tech
NEXT_PUBLIC_SITE_NAME=Astro Anil Joshi
NEXT_PUBLIC_CONTACT_EMAIL=hello@astroaniljoshi.tech
NEXT_PUBLIC_CONTACT_PHONE=+91 00000 00000

# --- Feature flags (optional — default salt matches config/feature-flags.json)
FLAG_SALT=anil_astro+1115

# --- Phase 1.5 only (leave commented until you enable the selfhost profile) ---
# POSTGRES_DB=anil_astro
# POSTGRES_USER=anil_astro
# POSTGRES_PASSWORD=change-me
# MINIO_ROOT_USER=anil_minio
# MINIO_ROOT_PASSWORD=change-me

# --- n8n automation (enable with: docker compose --profile automation up -d) ---
# N8N_BASIC_AUTH_USER=admin
# N8N_BASIC_AUTH_PASSWORD=change-me-strong-password
